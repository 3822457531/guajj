# MySQL 8（本地 Docker 见 docker-compose.yml 默认值）
DATABASE_URL="mysql://chigua:chigua@127.0.0.1:3306/chigua?charset=utf8mb4"

AUTH_SECRET="change-this-local-secret-before-production"

# 管理后台对外路径（勿用 /admin；部署后请自行换成更长随机串并保密）
ADMIN_PATH_PREFIX="/cp-VMmw84qnJz47xlO7"

# 访问统计 middleware → /api/analytics/collect 内部校验（默认同 AUTH_SECRET）
ANALYTICS_INTERNAL_SECRET="change-this-local-secret-before-production"

# 聚合登录（按实际后台填写）
SUYANW_APPID=
SUYANW_APPKEY=
SUYANW_REDIRECT_URI=https://your-domain/api/auth/social/callback

# 可选：Cloudflare R2（媒体存储为 r2 时使用）
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# 后台「站点设置 → 媒体存储」选 r2 并填写 bucket、公网前缀。
# 公网前缀 r2PublicBaseUrl 建议绑定自定义域名并开启 CDN（Orange Cloud），
# 视频缓存命中后浏览器直连 CDN，支持 Range/seek，体验远好于 API 代理流。
# 例：r2PublicBaseUrl = https://media.yourdomain.com （指向 R2 桶的 Custom Domain）

# ---------- TG 搜索媒体（超时 / 并发 / 预热）----------
# 缩略图/图片下载超时（毫秒，默认 90000）
# TG_SEARCH_MEDIA_DOWNLOAD_TIMEOUT_MS=90000
# 视频全量下载超时（毫秒，默认同 MEDIA；大文件建议 180000~300000）
# TG_SEARCH_VIDEO_DOWNLOAD_TIMEOUT_MS=180000
# 视频流式 chunk 大小（KB，默认 512）
# TG_SEARCH_VIDEO_STREAM_CHUNK_KB=512
# 视频 warm 单次最多排队条数（默认 8）
# TG_SEARCH_VIDEO_WARM_MAX=8
# 媒体 Worker 队列上限（默认 32）
# TG_SEARCH_MEDIA_WORKER_MAX_QUEUE=32
# R2 multipart 分片大小（MB，默认 8）与并发 part 数（默认 4）
# R2_MULTIPART_PART_SIZE_MB=8
# R2_MULTIPART_QUEUE_SIZE=4

# ---------- TG 采集（Userbot / GramJS，与 Bot Token 无关）----------
# 来自 https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
# 采集专用小号，国际格式
TG_PHONE=+86xxxxxxxxxxx
# 首次 npm run collector:login 后生成
TG_SESSION_FILE=./collector/session.txt
# 监控频道列表（也可 npm run collector:seed-channels 写入数据库）
TG_CHANNELS_FILE=./collector/channels.json
# 采集时下载图片/视频到本地 public/uploads 或 R2（0/false 关闭）
TG_DOWNLOAD_MEDIA=1

# 极搜人机验证：
#   web=返回验证码给网页用户选，GramJS 仅代点（推荐站点搜索）
#   auto=OCR自动 | wait=TG客户端手动 | manual=直接报错
JISOU_CAPTCHA_MODE=web
# web 验证码 challenge 有效期（毫秒）
JISOU_CAPTCHA_CHALLENGE_TTL_MS=120000
# wait 模式最长等待秒数（毫秒）
JISOU_CAPTCHA_WAIT_MS=90000
# 全网搜索：频道消息缩略图并发下载并上传 R2（默认 8，上限 12，遇 FloodWait 可调低到 4）
# TG_SEARCH_THUMB_CONCURRENCY=8
# TG_SEARCH_THUMB_MAX=12
# TG GramJS 连接：RPC 超时秒数（默认 120，大视频下载建议 180）
# TG_GRAM_RPC_TIMEOUT_SEC=180
# 空闲断连毫秒（默认 120000；下载进行中不会断连）
# TG_GRAM_IDLE_MS=120000
# 频道加载时后台 warm 视频条数（默认 2，0=关闭；避免占满带宽）
# TG_SEARCH_CHANNEL_WARM_MAX=2

# VIP 搜索 MySQL FULLTEXT（需已执行 init 迁移中的 ngram 索引；未建索引勿开启）
# VIP_SEARCH_FULLTEXT=1
